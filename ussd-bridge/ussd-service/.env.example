# =============================================================================
# TrustLedger USSD Service - Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── TrustLedger blockchain-core backend API ─────────────────────────────────
# Internal URL only (Docker: http://host.docker.internal:3000/api/v1 on Windows/Mac)
BACKEND_API_URL=http://localhost:3000/api/v1

# Must match USSD_SERVICE_KEY in blockchain-core/backend/.env (header X-Service-Key)
BACKEND_API_KEY=USSD_SERVICE_KEY=451f23eba5a4e405963d299639a006bb8f963927a465d8

# ─── Africa's Talking ────────────────────────────────────────────────────────
# Get from https://account.africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=atsk_f94efe95451f23eba5a4e405963d299639a006bb8f963927a465d8c75b50e80735d8e39c
AT_SHORTCODE=*384*123#

# ─── Redis (Session Store) ───────────────────────────────────────────────────
# Multi-step USSD state. On Railway: add Redis, reference REDIS_URL on the same service as the API (embedded bridge).
# TLS (Railway): URL often starts with rediss:// — supported by the session client.
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL=120            # Session TTL in seconds (USSD timeout)

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
