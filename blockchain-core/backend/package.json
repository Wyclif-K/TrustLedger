{
  "name": "trustledger-backend",
  "version": "1.0.0",
  "description": "TrustLedger SACCO - Node.js Backend API Gateway",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --runInBand",
    "test:watch": "jest --watch",
    "migrate": "npx prisma migrate deploy",
    "migrate:dev": "npx prisma migrate dev",
    "db:seed": "node seed.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "fabric:up": "docker compose -f ../blockchain/network/docker-compose.yaml up -d",
    "fabric:down": "docker compose -f ../blockchain/network/docker-compose.yaml down",
    "fabric:down:volumes": "docker compose -f ../blockchain/network/docker-compose.yaml down -v",
    "fabric:gen-artifacts": "powershell -ExecutionPolicy Bypass -File ../blockchain/scripts/fabric-gen-artifacts.ps1",
    "fabric:reset": "npm run fabric:down:volumes && npm run fabric:gen-artifacts && npm run fabric:up && npm run fabric:deploy",
    "fabric:deploy": "powershell -ExecutionPolicy Bypass -File ../blockchain/scripts/fabric-deploy.ps1",
    "fabric:upgrade": "powershell -ExecutionPolicy Bypass -File ../blockchain/scripts/fabric-upgrade.ps1",
    "lint": "eslint ."
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@hyperledger/fabric-gateway": "^1.4.0",
    "@prisma/client": "6.19.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^6.12.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "license": "MIT"
}
