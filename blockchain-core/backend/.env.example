# Copy to .env and adjust. Never commit .env.
#
# ── Railway — single HTTPS URL for admin + API (Dockerfile monolith) ─────────────────
# Dashboard: Root Directory = "blockchain-core" | Dockerfile = "Dockerfile" | add Postgres.
# Copy each line below into Railway → TrustLedger service → Variables (values are placeholders).
#
# NODE_ENV=production
# DATABASE_URL=postgresql://...@...postgres.railway.internal:5432/railway?sslmode=require
# JWT_SECRET=replace-with-long-random-string
# CORS_ORIGIN=https://YOUR-SERVICE.up.railway.app
#
# Optional (defaults are fine if omitted):
# API_PREFIX=/api/v1
# LOG_LEVEL=info
# SERVE_ADMIN_STATIC=true
#
# Single-URL deploy: do NOT set REFRESH_COOKIE_SAMESITE=none or VITE_API_BASE_URL.
#
# Fabric on Railway (PEM mode — use your VPS peer + open firewall for gRPC):
# FABRIC_ENABLED=true
# FABRIC_CHANNEL_NAME=trustledger-channel
# FABRIC_CHAINCODE_NAME=trustledger
# FABRIC_MSP_ID=SaccoOrgMSP
# FABRIC_PEER_ENDPOINT=your-vps-public-host:7051
# FABRIC_PEER_HOST_ALIAS=peer0.sacco.trustledger.com
# FABRIC_TLS_CERT_PEM=<paste full PEM>
# FABRIC_CERT_PEM=<paste full PEM>
# FABRIC_KEY_PEM=<paste full PEM>
#
# To run without Fabric first: FABRIC_ENABLED=false (blockchain routes return 503).

NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# PostgreSQL — matches docker-compose.yml in this folder (npm run db:up)
DATABASE_URL=postgresql://trustledger:trustledger@localhost:5432/trustledger
# Railway Postgres: add at end of DATABASE_URL if Prisma fails to connect: ?sslmode=require
# Optional startup connect timeout for clearer logs vs hanging (ms). Default 30000 on server boot.
# POSTGRES_CONNECT_TIMEOUT_MS=30000

# When true, serves ../admin-dashboard/dist from Express (same URL as API). Set by blockchain-core/Dockerfile for Railway.
# SERVE_ADMIN_STATIC=false

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173
# Production monolith on Railway: you can still point CORS_ORIGIN at your HTTPS URL explicitly, or omit updating it —
# the API allows browsers whose Origin hostname matches the request Host (see CORS_SAMEHOST_FALLBACK).
# Disable strict single-host check: CORS_SAMEHOST_FALLBACK=false
# Split deploy (admin on one host, API on another, e.g. two Railway services): set CORS_ORIGIN to the admin URL only
# (or comma-separated list). Then set cookies for cross-site API calls:
# REFRESH_COOKIE_SAMESITE=none
# Admin image is built with Docker ARG VITE_API_BASE_URL=https://your-api-host (see blockchain-core/Dockerfile.admin).

# Hyperledger Fabric — set true to use real chaincode (paths relative to this backend folder)
FABRIC_ENABLED=true
FABRIC_CHANNEL_NAME=trustledger-channel
FABRIC_CHAINCODE_NAME=trustledger
FABRIC_MSP_ID=SaccoOrgMSP
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_HOST_ALIAS=peer0.sacco.trustledger.com

# Peer TLS CA + Org Admin identity (from blockchain/network after crypto-gen)
FABRIC_TLS_CERT_PATH=../blockchain/network/crypto-config/peerOrganizations/sacco.trustledger.com/peers/peer0.sacco.trustledger.com/tls/ca.crt
FABRIC_CERT_PATH=../blockchain/network/crypto-config/peerOrganizations/sacco.trustledger.com/users/Admin@sacco.trustledger.com/msp/signcerts/Admin@sacco.trustledger.com-cert.pem
FABRIC_KEY_DIR=../blockchain/network/crypto-config/peerOrganizations/sacco.trustledger.com/users/Admin@sacco.trustledger.com/msp/keystore
#
# Railway / PaaS: paste PEM contents instead of paths (omit the three lines above when using PEM mode):
# FABRIC_TLS_CERT_PEM=-----BEGIN CERTIFICATE-----...
# FABRIC_CERT_PEM=-----BEGIN CERTIFICATE-----...
# FABRIC_KEY_PEM=-----BEGIN PRIVATE KEY-----...
# Point peer at your VPS/AWS peer (TLS + firewall must allow gRPC from Railway egress IPs):
# FABRIC_PEER_ENDPOINT=your-peer-host:7051

LOG_LEVEL=info
LOG_DIR=./logs
# Production default: stray Promise rejections log only (do not exit). To crash instead:
# EXIT_ON_UNHANDLED_REJECTION=true
# Docker/Railway: default file rotation off in production unless ENABLE_ROTATE_FILE_LOG=true
# ENABLE_ROTATE_FILE_LOG=false

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000
# Limiter applies only to /api/v1 (not static admin). Override in Railway as needed.

# USSD microservice (ussd-bridge) — must match BACKEND_API_KEY on the bridge; header X-Service-Key
USSD_SERVICE_KEY=ussd-service-internal-key-change-this

# Dev: SUPER_ADMIN can POST /api/v1/members/:memberId/purge-ledger (reuse member IDs on chain). Redeploy chaincode after pulling purgeLedgerMember.
# ALLOW_LEDGER_MEMBER_PURGE=true

# Africa's Talking (optional — enables SMS API + startup credential check; USSD webhook uses POST /api/v1/ussd)
# Sandbox app API key → use AT_USERNAME=sandbox (requests go to api.sandbox.africastalking.com automatically).
# Live app → your dashboard username + live API key on api.africastalking.com. Override with AT_SANDBOX=true|false.
AT_USERNAME=sandbox
AT_API_KEY=
# AT_SANDBOX=
# USSD dial string from your AT app (for your reference; configure the same in the AT dashboard callback URL)
AT_SHORTCODE=*384*123#
# If AT_SHORTCODE contains * or #, set a separate SMS sender for sendSms():
# AT_SMS_FROM=
# SMS member after admin dashboard deposit/withdraw (requires AT_USERNAME + AT_API_KEY). Set false to disable.
# AT_SMS_SAVINGS_ALERTS=true
